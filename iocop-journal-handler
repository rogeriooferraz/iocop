set -euo pipefail

STATE_DIR="/run/disk-io-watch"
LAST_FP_FILE="${STATE_DIR}/last_fp"
LAST_TS_FILE="${STATE_DIR}/last_ts"

mkdir -p "$STATE_DIR"

journalctl -kf -n0 -o cat | while IFS= read -r line; do
  if [[ "$line" =~ (Buffer\ I/O\ error|blk_update_request:\ I/O\ error|end_request:\ I/O\ error|I/O\ error,\ dev\ |critical\ medium\ error) ]]; then
    fp="$(printf '%s' "$line" | sha256sum | awk '{print $1}')"
    now="$(date +%s)"
    last_fp="$(cat "$LAST_FP_FILE" 2>/dev/null || true)"
    last_ts="$(cat "$LAST_TS_FILE" 2>/dev/null || echo 0)"

    if [[ "$fp" != "$last_fp" || $((now - last_ts)) -ge 5 ]]; then
      printf '%s' "$fp" > "$LAST_FP_FILE"
      printf '%s' "$now" > "$LAST_TS_FILE"

      /usr/local/sbin/iocop-notify-handler \
        "Disk I/O error detected" \
        "$line" \
        critical

      logger -t disk-io-watch -p daemon.err -- "$line"
    fi
  fi
done

set -euo pipefail

APP_NAME="iocop"
TITLE="${1:-IOCOP Notification}"
BODY="${2:-}"
URGENCY="${3:-normal}"

ICON_SVG="/usr/local/share/icons/hicolor/scalable/apps/iocop.svg"
ICON_PNG="/usr/local/share/icons/hicolor/48x48/apps/iocop.png"
FALLBACK_ICON="drive-harddisk"

ICON=""
BODY_IMAGE=""

if [ -r "$ICON_SVG" ]; then
    ICON="$ICON_SVG"
    BODY_IMAGE="$ICON_SVG"
elif [ -r "$ICON_PNG" ]; then
    ICON="$ICON_PNG"
    BODY_IMAGE="$ICON_PNG"
else
    ICON="$FALLBACK_ICON"
fi

NOTIFY_ARGS=(
    --app-name="$APP_NAME"
    --urgency="$URGENCY"
    --icon="$ICON"
)

if [ -n "$BODY_IMAGE" ]; then
    NOTIFY_ARGS+=(--hint="string:image-path:file://$BODY_IMAGE")
fi

while read -r sid _; do
    [ -n "$sid" ] || continue

    active="$(loginctl show-session "$sid" -p Active --value 2>/dev/null || true)"
    remote="$(loginctl show-session "$sid" -p Remote --value 2>/dev/null || true)"
    type="$(loginctl show-session "$sid" -p Type --value 2>/dev/null || true)"
    class="$(loginctl show-session "$sid" -p Class --value 2>/dev/null || true)"
    uid="$(loginctl show-session "$sid" -p User --value 2>/dev/null || true)"

    [ "$active" = "yes" ] || continue
    [ "$remote" = "no" ] || continue
    [[ "$type" = "x11" || "$type" = "wayland" ]] || continue
    [[ "$class" = "user" || "$class" = "greeter" ]] || continue
    [ -n "$uid" ] || continue
    [ -S "/run/user/$uid/bus" ] || continue

    sudo -u "#$uid" env \
        XDG_RUNTIME_DIR="/run/user/$uid" \
        DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$uid/bus" \
        /usr/bin/notify-send \
        "${NOTIFY_ARGS[@]}" \
        -- \
        "$TITLE" "$BODY"
done < <(loginctl list-sessions --no-legend)

exit 0
